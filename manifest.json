{
    "manifest_version": 3,
    "name": "ClaraFile+",
    "version": "1.0",
    "description": "Extra QOL-features for clarafile.cfgbonn.de",
    "browser_specific_settings": {
        "gecko": {
            "id": "clarafile+@mozilla.org",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "content_scripts": [
    {
      "matches": ["*://clarafile.cfgbonn.de/*"],
      "js": ["content.js"]
    }
  ]
}