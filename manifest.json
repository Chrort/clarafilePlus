{
    "manifest_version": 3,
    "name": "ClaraFile+",
    "version": "1.0",
    "description": "Extra QOL-features for clarafile.cfgbonn.de",
    "icons": {
        "48": "img/favicon.png"
    },
    "homepage_url": "https://github.com/Chrort/clarafilePlus",
    "browser_specific_settings": {
        "gecko": {
            "id": "clarafileplus@mozilla.org"
        }
    },
    "content_scripts": [
    {
      "matches": ["*://clarafile.cfgbonn.de/*"],
      "js": ["logout-btn.js", "dark-theme.js"],
      "css": ["dark-theme.css"]
    }
  ]
}